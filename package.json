{
  "name": "bloggy",
  "version": "1.0.0",
  "description": "A beautiful, minimal blog with an Obsidian-friendly writing workflow",
  "scripts": {
    "build": "node build.js && node build-movies.js",
    "build:posts": "node build.js",
    "build:movies": "node build-movies.js",
    "dev": "npm run build && npx -y live-server src --port=3000 --no-browser",
    "serve": "npx -y live-server src --port=3000"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0"
  },
  "keywords": [
    "blog",
    "markdown",
    "obsidian"
  ],
  "license": "MIT"
}
